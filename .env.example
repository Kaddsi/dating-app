# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_from_botfather
WEB_APP_URL=https://premium-dating-api.onrender.com/mini/

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dating_db
RUN_WITHOUT_DB=false

# API Configuration
API_SECRET_KEY=your-secret-key-change-this-in-production

# Frontend / Backend integration
API_BASE_URL=http://localhost:8000
WEB_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:5173,https://premium-dating-api.onrender.com

# Frontend Vite env
VITE_API_URL=http://localhost:8000
VITE_BOT_USERNAME=@your_bot_username

# Image Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Monitoring
SENTRY_DSN=your_sentry_dsn

# Environment
ENVIRONMENT=development
